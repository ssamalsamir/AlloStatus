# Leave everything blank to run in demo mode — the app boots against generated
# data with no database or sign-in. Fill these in to switch to the real,
# persistent experience (it activates automatically once DATABASE_URL and the
# Google credentials are present).

# --- Database (Neon Postgres via Vercel Marketplace) -------------------------
# Vercel auto-injects POSTGRES_URL on deploy. Locally we copy it into DATABASE_URL
# so drizzle-kit and our query client read the same name.
DATABASE_URL=

# --- Auth.js (NextAuth v5) ---------------------------------------------------
# 32+ random bytes, base64url. Generated during setup.
AUTH_SECRET=

# Google OAuth credentials. Created in Google Cloud Console → APIs & Services
# → Credentials → "OAuth client ID" (type: Web application).
# Authorized redirect URIs must include:
#   http://localhost:3000/api/auth/callback/google
#   https://<your-vercel-domain>/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# --- Background jobs ---------------------------------------------------------
# Protects the nightly Google Fit cron (/api/health/google). Set this in
# production; Vercel sends it as a bearer token on scheduled invocations.
CRON_SECRET=

# --- Chat (Gemini) -----------------------------------------------------------
# Powers the personalized chat widget. Get a key at https://aistudio.google.com/apikey
# Without it the chat still responds, with a note on how to enable it.
GEMINI_API_KEY=
# Optional: override the model (defaults to gemini-2.0-flash).
# GEMINI_MODEL=gemini-2.0-flash

# --- Optional ----------------------------------------------------------------
# Force demo mode even when the database and OAuth are configured.
# ALLOSTATUS_DEMO=1
